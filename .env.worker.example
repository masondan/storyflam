# Cloudflare Worker Environment Variables
# Copy this file to .env.worker and fill in your actual values

# Supabase Project URL
# Get this from your Supabase project settings
SUPABASE_URL=https://your-project.supabase.co

# Supabase Service Role Key
# Get this from your Supabase project settings (Settings > API)
# WARNING: This is a sensitive key - never commit the actual value
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Cloudflare KV Namespace ID (optional, auto-created by wrangler)
# Get this from `wrangler kv:namespace list`
KEEP_ALIVE_KV_ID=your-kv-namespace-id

# Cloudflare KV Namespace Preview ID (optional, for local testing)
KEEP_ALIVE_KV_PREVIEW_ID=your-kv-preview-namespace-id
