{
  "name": "newslab",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "worker:dev": "wrangler dev",
    "worker:deploy": "wrangler deploy --env production",
    "worker:logs": "wrangler tail --env production",
    "worker:kv:create": "wrangler kv:namespace create KEEP_ALIVE_KV && wrangler kv:namespace create KEEP_ALIVE_KV --preview"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260522.1",
    "@sveltejs/adapter-auto": "^3.0.0",
    "@sveltejs/adapter-cloudflare": "^7.2.4",
    "@sveltejs/kit": "^2.0.0",
    "@sveltejs/vite-plugin-svelte": "^3.0.0",
    "@types/node": "^20.10.6",
    "autoprefixer": "^10.4.16",
    "postcss": "^8.4.32",
    "svelte": "^4.2.8",
    "svelte-check": "^3.6.2",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.10",
    "wrangler": "^4.93.1"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.38.4",
    "jspdf": "^3.0.4",
    "plyr": "^3.8.4",
    "quill": "^2.0.3"
  }
}
